{% extends 'base.html.twig' %}

{% block title %}ServiceHUB{% endblock %}
{% block css %}
  <link rel="stylesheet" href="{{ asset('css/main.css') }}">
{% endblock %}


{% block body %}

  <div id="main">
  
    <div id="opis">
      <div id="opispierwszy">
        Miejsce, gdzie możesz ogłaszać usługi, dzielić talentami i odkrywać nowe możliwości
      </div>
      <div id="opisdrugi">
        Dołącz do nas i skorzystaj z bogactwa naszej społeczności!
      </div>
    </div>

    <div id="handshake">
      <img class="hand animate__animated animate__tada" src="{{ asset('images/hand_final.png') }}">
    </div>

  </div>

  <div id="search">
  
    <div id="wyszukaj">

      {{ form_start(quickSearchForm, {'action': path('app_skills_list')}) }}

        {{ form_widget(quickSearchForm.nazwaUslugi, {'attr': {'class': 'inputwyszukaj', 'placeholder': 'ZNAJDŹ COŚ, CO CIĘ INTERESUJE'}}) }}
        <button type="submit" id="btnwyszukaj">WYSZUKAJ</button>

      {{ form_end(quickSearchForm) }}
    
    </div>

    <div id="kreska"></div>

    <div id="promowanenapis">LOSOWE USŁUGI</div>
  
  </div>

  <div id="promowaneuslugi">
    
    <div id="boxlewo">
      <a href="{{ path('app_service_view', {idUslugi: randomServices[0].id}) }} ">
        <div class="uslugilewo">
          {% set imagePath = 'zdjeciaUslug/' ~ randomServices[0].uzytkownik.id ~ '/' ~ randomServices[0].id ~ '/' ~ randomServices[0].glowneZdjecie %}
          <img class="imgserviceleft" src="{{ asset(imagePath) }}">
          <div class="serivceopisleft">
            <div class="serviceopis textleft">{{ randomServices[0].nazwaUslugi }}</div>
            <div class="servicecena textleft">{{ randomServices[0].cena }} PLN{% if randomServices[0].czyStawkaGodzinowa %}/H{% endif %}</div>
            <div class="servicedata textleft">{{ randomServices[0].uzytkownik.daneUzytkownika.miasto }}<br>DODANO {{ randomServices[0].dataDodania|date('d.m.Y') }}</div>   
          </div>
        
        </div>
      </a>

      <a href="{{ path('app_service_view', {idUslugi: randomServices[1].id}) }} ">
        <div class="uslugilewo mgtop">
          {% set imagePath = 'zdjeciaUslug/' ~ randomServices[1].uzytkownik.id ~ '/' ~ randomServices[1].id ~ '/' ~ randomServices[1].glowneZdjecie %}
          <img class="imgserviceleft" src="{{ asset(imagePath) }}">
          <div class="serivceopisleft">
            <div class="serviceopis textleft">{{ randomServices[1].nazwaUslugi }}</div>
            <div class="servicecena textleft">{{ randomServices[1].cena }} PLN{% if randomServices[1].czyStawkaGodzinowa %}/H{% endif %}</div>
            <div class="servicedata textleft">{{ randomServices[1].uzytkownik.daneUzytkownika.miasto }}<br>DODANO {{ randomServices[1].dataDodania|date('d.m.Y') }}</div>   
          </div>
        
        </div>
      </a>
    </div>

    <div id="kreskaczarna"></div>

    <div id="boxprawo">
      <a href="{{ path('app_service_view', {idUslugi: randomServices[2].id}) }} ">
        <div class="uslugiprawo">
          {% set imagePath = 'zdjeciaUslug/' ~ randomServices[2].uzytkownik.id ~ '/' ~ randomServices[2].id ~ '/' ~ randomServices[2].glowneZdjecie %}
          <img class="imgserviceright" src="{{ asset(imagePath) }}">
          <div class="serivceopisright">
            <div class="serviceopis textright">{{ randomServices[2].nazwaUslugi }}</div>
            <div class="servicecena textright">{{ randomServices[2].cena }} PLN{% if randomServices[2].czyStawkaGodzinowa %}/H{% endif %}</div>
            <div class="servicedata textright">{{ randomServices[2].uzytkownik.daneUzytkownika.miasto }}<br>DODANO {{ randomServices[2].dataDodania|date('d.m.Y') }}</div>   
          </div>
        
        </div>
      </a>

      <a href="{{ path('app_service_view', {idUslugi: randomServices[3].id}) }} ">
        <div class="uslugiprawo mgtop">
          {% set imagePath = 'zdjeciaUslug/' ~ randomServices[3].uzytkownik.id ~ '/' ~ randomServices[3].id ~ '/' ~ randomServices[3].glowneZdjecie %}
          <img class="imgserviceright" src="{{ asset(imagePath) }}">
          <div class="serivceopisright">
            <div class="serviceopis textright">{{ randomServices[3].nazwaUslugi }}</div>
            <div class="servicecena textright">{{ randomServices[3].cena }} PLN{% if randomServices[3].czyStawkaGodzinowa %}/H{% endif %}</div>
            <div class="servicedata textright">{{ randomServices[3].uzytkownik.daneUzytkownika.miasto }}<br>DODANO {{ randomServices[3].dataDodania|date('d.m.Y') }}</div>   
          </div>
        
        </div>
      </a>
    </div>

  </div>

  <div id="statystyki">
  
    <div class="stat rt statleft">
    
      <div class="circle"><img src="{{ asset('images/klients.png') }}"></div>
      <div class="statopis">
        <div class="statnumber">{{ users|length }}</div>
        <div class="statname">ZADOWOLONYCH UŻYTKOWNIKÓW</div>
      </div>
    
    </div>

    <div class="statkreska rt2"></div>

    <div class="stat2 rt">
    
      <div class="circle"><img src="{{ asset('images/calender.png') }}"></div>
      <div class="statopis">
        <div class="statnumber">{{ reservations|length }}</div>
        <div class="statname">WYKONANYCH REZERWACJI</div>
      </div>
    
    </div>

    <div class="statkreska rt2"></div>

    <div class="stat2">
    
      <div class="circle"><img src="{{ asset('images/service.png') }}"></div>
      <div class="statopis">
        <div class="statnumber">{{ allServices|length }}</div>
        <div class="statname">DOSTĘPNYCH USŁUG</div>
      </div>
    
    </div>
  
  </div>

  <script>
  
    function handShake(){
      if (window.location.pathname === '/main') {
        let z = document.getElementsByClassName('hand');
        if (z.length > 0) {
          z[0].classList.remove("animate__tada");
          setTimeout(function(){
            z[0].classList.add("animate__tada");
          }, 2000);
        }
      }
    }

    setInterval(handShake, 10000);
  
  </script>

{% endblock %}
