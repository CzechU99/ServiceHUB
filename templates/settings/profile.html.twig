{% extends 'base.html.twig' %}

{% block title %}ServiceHUB - PROFIL{% endblock %}
{% block css %}
  <link rel="stylesheet" href="{{ asset('css/profile.css') }}">
{% endblock %}

{% block body %}

  <div id="menu">
  
    <div id="setts">
      
      <a href="{{path('app_myservices')}}"><div class="przycisk">MOJE USŁUGI</div></a>
      <a href="{{path('app_rezerwacje')}}"><div class="przycisk">REZERWACJE I WYMIANY</div></a>
      <a href="{{path('app_profile')}}"><div class="przycisk {% if app.request.pathinfo == "/profile" %}clicked{% endif %}">DANE</div></a>
      <a href="{{path('app_obserwowane')}}"><div class="przycisk">OBSERWOWANE</div></a>

    </div>
  
  </div>

  <div id="info">

    <div class="flashinfo">

      {% set break = false %}
      {% for child in profileForm.children %}
        {% for error in child.vars.errors %}
          {% if not break %}
            <div class="error-message">
                {{ error.message|upper }}
            </div>
          {% endif %}
          {% set break = true %}
        {% endfor %}
      {% endfor %}

      {% for flash_msg in app.flashes('error') %}
        <div class="error-message">{{ flash_msg|upper }}</div>
      {% endfor %}

      {% for flash_msg in app.flashes('success') %}
        <div class="success">{{ flash_msg|upper }}</div>
      {% endfor %}
    
    </div>

    <div id="all">

      {{ form_start(profileForm) }}

        {{ form_errors(profileForm) }}

        <div class="box">
        
          <div class="opis left pd">IMIE</div>
          <div class="opis right pd">NAZWISKO</div>
        
        </div>

        <div class="box">

          {{ form_widget(profileForm.imie, {'attr': {'class': 'dane left', 'placeholder': 'PODAJ IMIE...'}}) }}

          {{ form_widget(profileForm.nazwisko, {'attr': {'class': 'dane right', 'placeholder': 'PODAJ NAZWISKO...'}}) }}

        </div>

        <div class="box">
        
          <div class="opis left pd">ULICA</div>
          <div class="opis right pd">NUMER DOMU</div>
        
        </div>

        <div class="box">

          {{ form_widget(profileForm.miejscowosc, {'attr': {'class': 'dane left', 'placeholder': 'PODAJ ULICE...'}}) }}
          {{ form_widget(profileForm.numer_domu, {'attr': {'class': 'dane right', 'placeholder': 'PODAJ NUMER DOMU...'}}) }}

        </div>

        <div class="box">
        
          <div class="opis left pd">KOD POCZTOWY</div>
          <div class="opis right pd">MIASTO</div>
        
        </div>

        <div class="box">

          {{ form_widget(profileForm.kod_pocztowy, {'attr': {'class': 'dane left', 'placeholder': 'PODAJ KOD POCZTOWY...'}}) }}
          {{ form_widget(profileForm.miasto, {'attr': {'class': 'dane right', 'placeholder': 'PODAJ MISATO...'}}) }}

        </div>

        <div class="box">
        
          <div class="opis left pd">TELEFON</div>
        
        </div>

        <div class="box">

          {{ form_widget(profileForm.telefon, {'attr': {'class': 'dane left', 'placeholder': 'PODAJ TELEFON Z PREFIKSEM...'}}) }}

        </div>

        <button type="submit" id="btnzaloguj">ZAPISZ</button>

      {{ form_end(profileForm) }}

    </div>
  
  </div>
    

{% endblock %}
